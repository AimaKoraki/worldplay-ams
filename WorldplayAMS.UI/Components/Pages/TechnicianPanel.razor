@page "/technician"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Technician")]
@inject IHttpClientFactory ClientFactory

<PageTitle>Worldplay AMS — Diagnostics</PageTitle>

<div class="tech-wrap">

    <!-- Page Header -->
    <div class="page-header mb-5">
        <div>
            <h1 class="page-title">
                <span class="bi bi-gpu-card me-3" style="color:var(--neon-cyan);"></span>Asset Diagnostics
            </h1>
            <p class="page-subtitle">Monitor and control all arcade hardware nodes in real-time</p>
        </div>
        <div class="header-actions">
            <button class="btn-neon btn-neon-cyan" @onclick="LoadMachines">
                <span class="bi bi-arrow-repeat"></span> Sync Nodes
            </button>
        </div>
    </div>

    <!-- Status Summary Strip -->
    <div class="status-strip mb-5">
        <div class="strip-item">
            <span class="bi bi-check-circle-fill" style="color:var(--status-active);"></span>
            <span>@machines?.Count(m => m.Status == "Online") Online</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-broadcast" style="color:var(--status-logging);"></span>
            <span>@machines?.Count(m => m.Status == "InUse") In Use</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-exclamation-triangle-fill" style="color:var(--status-error);"></span>
            <span>@machines?.Count(m => m.Status == "Maintenance") Maintenance</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-hdd-stack-fill" style="color:var(--text-secondary);"></span>
            <span>@machines?.Count Total Nodes</span>
        </div>
    </div>

    @if (machines == null)
    {
        <div class="empty-state-full">
            <span class="bi bi-arrow-repeat rotating" style="font-size:2.5rem; color:var(--neon-cyan);"></span>
            <p class="mt-3">Enumerating hardware nodes...</p>
        </div>
    }
    else if (!machines.Any())
    {
        <div class="glass-card empty-state-full">
            <span class="bi bi-exclamation-octagon" style="font-size:3rem; color:var(--text-disabled);"></span>
            <h3 class="mt-3 text-white">No Hardware Nodes Detected</h3>
            <p class="mt-1 text-muted-custom">Check your network connection or API endpoint.</p>
        </div>
    }
    else
    {
        <div class="machine-grid">
            @foreach (var m in machines)
            {
                var statusClass = m.Status == "InUse" ? "inuse" : (m.Status == "Maintenance" ? "maint" : "online");
                var typeColor = m.MachineType == "VR Unit" ? "info" : (m.MachineType == "Classic" ? "warning" : "active");

                <div class="machine-card glass-card status-@statusClass">
                    <!-- Card top accent bar -->
                    <div class="machine-accent-bar"></div>

                    <!-- Header row -->
                    <div class="machine-header">
                        <div class="machine-icon-wrap status-icon-@statusClass">
                            <span class="bi @(m.MachineType == "VR Unit" ? "bi-headset-vr" : (m.MachineType == "Classic" ? "bi-joystick" : "bi-trophy-fill"))"></span>
                        </div>
                        <div class="machine-title-block">
                            <h3 class="machine-name">@m.Name</h3>
                            <span class="badge-neon @typeColor">@m.MachineType</span>
                        </div>
                    </div>

                    <!-- Status row -->
                    <div class="machine-status-row">
                        @if (m.Status == "InUse")
                        {
                            <span class="pulse-dot logging"></span>
                            <span class="status-label" style="color:var(--status-logging);">Session Active</span>
                        }
                        else if (m.Status == "Maintenance")
                        {
                            <span class="pulse-dot maint"></span>
                            <span class="status-label" style="color:var(--status-error);">Under Maintenance</span>
                        }
                        else
                        {
                            <span class="pulse-dot online"></span>
                            <span class="status-label" style="color:var(--status-active);">Online · Idle</span>
                        }
                    </div>

                    <!-- Meta info -->
                    <div class="machine-meta">
                        <div class="meta-item">
                            <span class="meta-label">Node ID</span>
                            <span class="meta-value font-mono">@m.Id.ToString().Substring(0, 8).ToUpper()</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Type</span>
                            <span class="meta-value">@m.MachineType</span>
                        </div>
                    </div>

                    <!-- Action button -->
                    <div class="machine-action">
                        @if (m.Status == "Maintenance")
                        {
                            <button class="btn-neon btn-neon-red w-100" disabled>
                                <span class="bi bi-lock-fill"></span> Node Locked
                            </button>
                        }
                        else
                        {
                            <button class="btn-neon w-100 @(m.Status == "InUse" ? "btn-neon-purple" : "btn-primary-action")"
                                    @onclick="() => ToggleMachine(m)">
                                @if (m.Status == "InUse")
                                {
                                    <span class="bi bi-stop-circle-fill"></span>
                                    <span>End Session</span>
                                }
                                else
                                {
                                    <span class="bi bi-play-circle-fill"></span>
                                    <span>Start Session</span>
                                }
                            </button>
                        }
                    </div>

                    <!-- Feedback toast -->
                    @if (messageId == m.Id && !string.IsNullOrEmpty(feedbackMessage))
                    {
                        <div class="machine-feedback">
                            <span class="bi bi-info-circle-fill me-1"></span>@feedbackMessage
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
    /* Page layout */
    .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 40%, var(--neon-cyan) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
        display: flex;
        align-items: center;
    }
    .page-subtitle { color: var(--text-secondary); font-size: 0.875rem; margin-top: 0.3rem; }

    /* Status summary strip */
    .status-strip {
        display: flex;
        align-items: center;
        gap: 0;
        background: var(--surface-base);
        border: 1px solid var(--surface-border);
        border-radius: var(--radius-md);
        padding: 0.9rem 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .strip-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-heading);
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-secondary);
    }
    .strip-divider { width: 1px; height: 20px; background: var(--surface-border); flex-shrink: 0; }

    /* Machine grid */
    .machine-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
        gap: 1.5rem;
    }

    /* Machine card overrides */
    .machine-card {
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .machine-card:hover { transform: translateY(-4px); }

    .machine-accent-bar {
        height: 3px;
        width: 100%;
    }
    .machine-card.status-online .machine-accent-bar  { background: linear-gradient(90deg, var(--status-active), transparent); }
    .machine-card.status-inuse .machine-accent-bar   { background: linear-gradient(90deg, var(--status-logging), transparent); }
    .machine-card.status-maint .machine-accent-bar   { background: linear-gradient(90deg, var(--status-error), transparent); }

    .machine-card.status-inuse  { box-shadow: var(--shadow-card), 0 0 20px rgba(41,121,255,0.12); }
    .machine-card.status-online { box-shadow: var(--shadow-card), 0 0 20px rgba(0,230,118,0.08); }
    .machine-card.status-maint  { opacity: 0.85; }

    /* Inner padding wrapper */
    .machine-header, .machine-status-row, .machine-meta, .machine-action, .machine-feedback {
        padding: 0 1.5rem;
    }

    .machine-header {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding-top: 1.5rem;
        padding-bottom: 1rem;
    }

    .machine-icon-wrap {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }
    .status-icon-online  { background: rgba(0,230,118,0.12); color: var(--status-active); }
    .status-icon-inuse   { background: rgba(41,121,255,0.12); color: var(--status-logging); }
    .status-icon-maint   { background: rgba(255,61,87,0.12);  color: var(--status-error); }

    .machine-title-block { flex: 1; }
    .machine-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
        line-height: 1.3;
    }

    /* Status row */
    .machine-status-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(0,0,0,0.25);
        margin: 0 1.5rem;
        border-radius: 8px;
        padding: 0.65rem 1rem;
        font-family: var(--font-heading);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }
    .pulse-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .pulse-dot.online  { background: var(--status-active); box-shadow: 0 0 8px var(--status-active); }
    .pulse-dot.logging { background: var(--status-logging); box-shadow: 0 0 8px var(--status-logging); animation: blink 1.4s ease-in-out infinite; }
    .pulse-dot.maint   { background: var(--status-error); }

    /* Meta info */
    .machine-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        padding-top: 1rem;
        padding-bottom: 1rem;
    }
    .meta-item { display: flex; flex-direction: column; gap: 2px; }
    .meta-label { font-size: 0.65rem; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: var(--text-disabled); }
    .meta-value { font-size: 0.82rem; font-weight: 600; color: var(--text-primary); }

    /* Action */
    .machine-action { padding-bottom: 1.5rem; }

    /* Feedback */
    .machine-feedback {
        margin-bottom: 1rem;
        padding: 0.6rem 1.5rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--neon-amber);
        background: rgba(255,184,0,0.08);
        border-top: 1px solid rgba(255,184,0,0.15);
        animation: slideUp 0.3s ease;
    }

    /* Empty states */
    .empty-state-full {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-height: 280px; text-align: center; color: var(--text-secondary);
    }
</style>

@code {
    private List<MachineDto> machines = default!;
    private string feedbackMessage = string.Empty;
    private Guid messageId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMachines();
    }

    private async Task LoadMachines()
    {
        var client = ClientFactory.CreateClient("ApiClient");
        try
        {
            var result = await client.GetFromJsonAsync<List<MachineDto>>("/api/machines");
            machines = result ?? new();
        }
        catch
        {
            // Fallback: if API is unreachable, show demo data so the UI isn't blank
            machines = new List<MachineDto>
            {
                new() { Id = Guid.NewGuid(), Name = "VR Station 1 — Beat Saber", MachineType = "VR Unit",  Status = "Online" },
                new() { Id = Guid.NewGuid(), Name = "VR Station 2 — Racing Sim", MachineType = "VR Unit",  Status = "InUse" },
                new() { Id = Guid.NewGuid(), Name = "Arcade Cab — PacMan",        MachineType = "Classic",  Status = "Online" },
                new() { Id = Guid.NewGuid(), Name = "Claw Machine V2",            MachineType = "Prize",    Status = "Maintenance" }
            };
        }
    }

    private async Task ToggleMachine(MachineDto machine)
    {
        var currentStatus = machine.Status;
        machine.Status = currentStatus == "InUse" ? "Online" : "InUse";

        var client = ClientFactory.CreateClient("ApiClient");
        try
        {
            var response = await client.PostAsJsonAsync("/api/machines/toggle", new { MachineId = machine.Id });
            var resultMessage = await response.Content.ReadAsStringAsync();

            messageId = machine.Id;
            feedbackMessage = resultMessage.Trim('"');
        }
        catch
        {
            machine.Status = currentStatus;
            messageId = machine.Id;
            feedbackMessage = "ERR: Network unreachable — change reverted.";
        }
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            if (messageId == machine.Id)
            {
                feedbackMessage = "";
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private class MachineDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string MachineType { get; set; } = string.Empty;
        public string Status { get; set; } = "Online";
    }
}
