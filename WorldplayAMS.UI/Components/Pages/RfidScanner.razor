@page "/scanner"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Staff")]
@inject IHttpClientFactory ClientFactory

<PageTitle>Worldplay AMS - RFID Scanner</PageTitle>

<div class="scanner-container" @onclick="FocusInput">
    <div class="scanner-card">
        <div class="icon-pulse">
            <i class="rfid-icon">RFID</i>
        </div>
        <h1>Tap RFID to Check-in/Out</h1>
        <p class="subtitle">Please hold your wristband near the reader.</p>
        
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="status-banner @(isError ? "error" : "success")">
                @statusMessage
            </div>
        }
    </div>

    <!-- Hidden input to capture the USB RFID wedge reader input -->
    <!-- Actively binds to keystrokes ending with 'Enter' -->
    <input type="text" 
           class="hidden-input" 
           @bind="scannedTag" 
           @bind:event="oninput"
           @onkeyup="HandleKeyUp" 
           @ref="rfidInputRef" 
           autofocus />
</div>

<style>
    :root {
        --primary-bg: #1e1e2f;
        --card-bg: #2a2a40;
        --text-color: #ffffff;
        --success-color: #4cd137;
        --error-color: #e84118;
    }

    body {
        margin: 0;
        background-color: var(--primary-bg);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .scanner-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        width: 100vw;
    }

    .scanner-card {
        background-color: var(--card-bg);
        padding: 4rem;
        border-radius: 24px;
        text-align: center;
        color: var(--text-color);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        max-width: 600px;
        width: 90%;
    }

    .scanner-card h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        font-size: 1.2rem;
        color: #a4b0be;
        margin-bottom: 2rem;
    }

    .icon-pulse {
        width: 120px;
        height: 120px;
        background: rgba(76, 209, 55, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem auto;
        animation: pulse 2s infinite;
    }

    .icon-pulse .rfid-icon {
        font-size: 2rem;
        font-weight: bold;
        color: var(--success-color);
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(76, 209, 55, 0.4); }
        70% { box-shadow: 0 0 0 30px rgba(76, 209, 55, 0); }
        100% { box-shadow: 0 0 0 0 rgba(76, 209, 55, 0); }
    }

    .hidden-input {
        position: absolute;
        opacity: 0;
        top: -1000px; /* Keep it off-screen */
    }

    .status-banner {
        padding: 1.5rem;
        border-radius: 12px;
        font-size: 1.5rem;
        font-weight: 600;
        margin-top: 2rem;
        animation: fadeIn 0.3s ease-out;
    }

    .status-banner.success {
        background-color: rgba(76, 209, 55, 0.2);
        color: var(--success-color);
        border: 2px solid var(--success-color);
    }

    .status-banner.error {
        background-color: rgba(232, 65, 24, 0.2);
        color: var(--error-color);
        border: 2px solid var(--error-color);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private string scannedTag = string.Empty;
    private string statusMessage = string.Empty;
    private bool isError = false;
    private ElementReference rfidInputRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FocusInput();
        }
    }

    private async Task FocusInput()
    {
        try { await rfidInputRef.FocusAsync(); } catch { }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        // Standard USB readers act as a keyboard and emit "Enter" at the end of the scan
        if (e.Key == "Enter")
        {
            if (!string.IsNullOrWhiteSpace(scannedTag))
            {
                await ProcessTap(scannedTag);
            }
            scannedTag = string.Empty; // Reset string for the next scan
        }
    }

    private async Task ProcessTap(string tagStr)
    {
        var client = ClientFactory.CreateClient("ApiClient");
        try
        {
            // Call API backend which leverages SessionManagerService.ProcessRfidTapAsync
            var response = await client.PostAsJsonAsync("/api/sessions/process-tap", new { TagString = tagStr });
            var resultMessage = await response.Content.ReadAsStringAsync();

            isError = resultMessage.StartsWith("Error", StringComparison.OrdinalIgnoreCase);
            statusMessage = resultMessage.Trim('"');
        }
        catch (Exception)
        {
            // Trigger optimistic fallback UI indicating offline log
            isError = true;
            statusMessage = "Offline: Tap recorded locally. Will sync when online.";
        }

        StateHasChanged();
        
        // Auto-clear message after 3 seconds to get ready for the next guest
        _ = Task.Run(async () =>
        {
            await Task.Delay(3000);
            statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        });
    }
}
