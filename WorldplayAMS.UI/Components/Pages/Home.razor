@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IHttpClientFactory ClientFactory

<PageTitle>Worldplay AMS — Dashboard</PageTitle>

<div class="dashboard-wrap">

    <!-- Page Header -->
    <div class="page-header mb-5">
        <div>
            <h1 class="page-title">Control Center</h1>
            <p class="page-subtitle">Real-time overview of arcade terminals and session activity</p>
        </div>
        <div class="header-actions">
            <button class="btn-neon btn-neon-cyan" @onclick="LoadSessions">
                <span class="bi bi-arrow-repeat"></span> Refresh
            </button>
        </div>
    </div>

    <!-- KPI Stats Row -->
    <div class="kpi-row mb-5">
        <div class="stat-card accent-green">
            <div class="stat-icon" style="background:rgba(0,230,118,0.12); color:var(--status-active);">
                <span class="bi bi-display"></span>
            </div>
            <div>
                <div class="stat-value">@activeSessions.Count</div>
                <div class="stat-label">Active Sessions</div>
            </div>
        </div>
        <div class="stat-card accent-cyan">
            <div class="stat-icon" style="background:rgba(0,240,255,0.1); color:var(--neon-cyan);">
                <span class="bi bi-people-fill"></span>
            </div>
            <div>
                <div class="stat-value">@activeSessions.Count</div>
                <div class="stat-label">Players Online</div>
            </div>
        </div>
        <div class="stat-card accent-amber">
            <div class="stat-icon" style="background:rgba(255,184,0,0.1); color:var(--neon-amber);">
                <span class="bi bi-clock-history"></span>
            </div>
            <div>
                <div class="stat-value">@machineCount</div>
                <div class="stat-label">Total Machines</div>
            </div>
        </div>
        <div class="stat-card accent-purple">
            <div class="stat-icon" style="background:rgba(157,0,255,0.1); color:var(--neon-purple);">
                <span class="bi bi-lightning-charge-fill"></span>
            </div>
            <div>
                <div class="stat-value">₹@todayRevenue.ToString("F2")</div>
                <div class="stat-label">Today's Revenue</div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="dashboard-grid">

        <!-- Quick Actions Panel -->
        <section class="glass-card quick-actions-panel" style="border-top: 3px solid var(--neon-cyan);">
            <p class="section-title"><span class="bi bi-lightning-fill text-cyan"></span> Quick Actions</p>

            <button class="btn-neon btn-primary-action w-100 quick-action-btn mb-3" @onclick="SimulateRfidTap">
                <span class="bi bi-upc-scan fs-5"></span>
                <span>
                    <span class="d-block" style="font-size:1rem;">Force Network Ping</span>
                    <span class="d-block" style="font-size:0.72rem; opacity:0.75; font-weight:400;">Simulate RFID tap event</span>
                </span>
            </button>

            <a href="/scanner" class="btn-neon btn-neon-cyan w-100 quick-action-btn mb-3">
                <span class="bi bi-radar fs-5"></span>
                <span>
                    <span class="d-block" style="font-size:1rem;">Open Scanner</span>
                    <span class="d-block" style="font-size:0.72rem; opacity:0.75; font-weight:400;">RFID check-in terminal</span>
                </span>
            </a>

            <a href="/technician" class="btn-neon btn-neon-purple w-100 quick-action-btn">
                <span class="bi bi-gpu-card fs-5"></span>
                <span>
                    <span class="d-block" style="font-size:1rem;">Diagnostics Panel</span>
                    <span class="d-block" style="font-size:0.72rem; opacity:0.75; font-weight:400;">Manage machine states</span>
                </span>
            </a>
        </section>

        <!-- Live Sessions Table -->
        <section class="glass-card" style="border-top: 3px solid var(--neon-purple);">
            <p class="section-title"><span class="bi bi-activity text-purple"></span> Live Sessions</p>

            @if (activeSessions == null)
            {
                <div class="empty-state">
                    <span class="bi bi-hourglass-split rotating" style="font-size:2rem; color:var(--text-secondary);"></span>
                    <p class="mt-3">Establishing connection...</p>
                </div>
            }
            else if (!activeSessions.Any())
            {
                <div class="empty-state">
                    <span class="bi bi-hdd-network" style="font-size:2.5rem; color:var(--text-disabled);"></span>
                    <p class="mt-3">No active sessions detected.</p>
                    <span class="badge-neon idle mt-2">All Terminals Idle</span>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table-glass">
                        <thead>
                            <tr>
                                <th>Session ID</th>
                                <th>Tag ID</th>
                                <th>Started</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in activeSessions)
                            {
                                <tr>
                                    <td class="font-mono text-cyan fw-bold" style="font-size:0.82rem;">
                                        #@session.Id.ToString().Substring(0, 8).ToUpper()
                                    </td>
                                    <td class="text-white fw-medium font-mono" style="font-size:0.82rem;">@session.RfidTagId.ToString().Substring(0, 8).ToUpper()</td>
                                    <td class="text-muted-custom" style="font-size:0.82rem;">@session.StartTime.ToLocalTime().ToString("HH:mm")</td>
                                    <td><span class="badge-neon active"><span class="bi bi-record-circle-fill"></span> Active</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

    </div>
</div>

<style>
    .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .page-title {
        font-size: 1.9rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, #fff 40%, var(--neon-cyan) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }
    .page-subtitle { color: var(--text-secondary); font-size: 0.9rem; margin-top: 0.3rem; }

    .kpi-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.25rem;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    @@media (min-width: 900px) {
        .dashboard-grid { grid-template-columns: 300px 1fr; }
    }

    .quick-action-btn {
        border-radius: 10px;
        padding: 1rem 1.25rem;
        justify-content: flex-start;
        gap: 1rem;
        text-align: left;
        height: auto;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 220px;
        color: var(--text-secondary);
        text-align: center;
    }

    .fw-medium { font-weight: 500; }
</style>

@code {
    private List<SessionDto> activeSessions = new();
    private HttpClient httpClient = default!;
    private int machineCount = 0;
    private decimal todayRevenue = 0;

    protected override async Task OnInitializedAsync()
    {
        httpClient = ClientFactory.CreateClient("ApiClient");
        await Task.WhenAll(LoadSessions(), LoadMachineCount(), LoadTodayRevenue());
    }

    private async Task LoadSessions()
    {
        try
        {
            var result = await httpClient.GetFromJsonAsync<List<SessionDto>>("/api/sessions/active");
            activeSessions = result ?? new();
        }
        catch
        {
            activeSessions = new();
        }
    }

    private async Task LoadMachineCount()
    {
        try
        {
            var machines = await httpClient.GetFromJsonAsync<List<object>>("/api/machines");
            machineCount = machines?.Count ?? 0;
        }
        catch
        {
            machineCount = 0;
        }
    }

    private async Task LoadTodayRevenue()
    {
        try
        {
            todayRevenue = await httpClient.GetFromJsonAsync<decimal>("/api/sessions/revenue/today");
        }
        catch
        {
            todayRevenue = 0;
        }
    }

    private async Task SimulateRfidTap()
    {
        try
        {
            await httpClient.PostAsJsonAsync("/api/sessions/process-tap", new { TagString = "DEMO-TAG-001" });
            await LoadSessions();
        }
        catch
        {
            activeSessions.Insert(0, new SessionDto { Id = Guid.NewGuid(), RfidTagId = Guid.NewGuid(), StartTime = DateTime.Now, Status = "Active" });
        }
    }

    private class SessionDto
    {
        public Guid Id { get; set; }
        public Guid RfidTagId { get; set; }
        public DateTime StartTime { get; set; }
        public string Status { get; set; } = string.Empty;
        public int? TotalDurationMinutes { get; set; }
        public decimal? Fee { get; set; }
    }
}
