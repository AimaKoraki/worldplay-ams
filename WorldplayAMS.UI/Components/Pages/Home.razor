@page "/"
@inject IHttpClientFactory ClientFactory

<PageTitle>Worldplay AMS Dashboard</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>Worldplay AMS</h1>
        <div class="status-indicator">
            <span class="dot online"></span> System Online
        </div>
    </header>

    <main class="dashboard-grid">
        <section class="card quick-actions">
            <h2>Quick Actions</h2>
            <button class="btn btn-primary btn-large" @onclick="SimulateRfidTap">
                <i class="icon-tap"></i> Simulate RFID Tap
            </button>
        </section>

        <section class="card active-sessions">
            <h2>Active Sessions</h2>
            @if (activeSessions == null)
            {
                <p>Loading sessions...</p>
            }
            else if (!activeSessions.Any())
            {
                <p>No active sessions.</p>
            }
            else
            {
                <ul class="session-list">
                    @foreach (var session in activeSessions)
                    {
                        <li>Session @session.Id.Substring(0, 8) - Machine @session.MachineId.Substring(0, 8)</li>
                    }
                </ul>
            }
        </section>
    </main>
</div>

<style>
    :root {
        --primary-color: #4CAF50;
        --bg-color: #f4f7f6;
        --card-bg: #ffffff;
        --text-main: #333333;
    }

    body {
        margin: 0;
        background-color: var(--bg-color);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .dashboard-container {
        padding: 2rem;
        max-width: 1200px;
        margin: auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .dashboard-header h1 {
        font-weight: 700;
        color: var(--text-main);
        font-size: 2.5rem;
    }

    .status-indicator {
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        color: #555;
    }

    .dot {
        height: 15px;
        width: 15px;
        background-color: #ccc;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

    .dot.online { background-color: var(--primary-color); }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 2rem;
        /* iPad landscape layout optimization */
    }

    .card {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .card h2 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        border-bottom: 2px solid #eee;
        padding-bottom: 0.5rem;
    }

    .btn {
        width: 100%;
        padding: 1.5rem;
        font-size: 1.4rem;
        font-weight: bold;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: transform 0.1s;
    }

    .btn:active {
        transform: scale(0.98);
    }

    .btn-primary {
        background-color: var(--primary-color);
        color: white;
        box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);
    }

    .session-list {
        list-style: none;
        padding: 0;
    }

    .session-list li {
        padding: 1rem;
        background: #fafafa;
        margin-bottom: 0.5rem;
        border-radius: 8px;
        font-family: monospace;
        font-size: 1.1rem;
    }
</style>

@code {
    private List<dynamic> activeSessions = new();
    private HttpClient httpClient = default!;
    
    protected override async Task OnInitializedAsync()
    {
        httpClient = ClientFactory.CreateClient("ApiClient");
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        await Task.CompletedTask; // Suppress CS1998 warning since API call is mocked
        try
        {
            // In a real environment, un-mock this.
            // activeSessions = await httpClient.GetFromJsonAsync<List<dynamic>>("/api/sessions/active") ?? new();
            
            // Mock data simulating fast response
            activeSessions = new List<dynamic>
            {
                new { Id = Guid.NewGuid().ToString(), MachineId = Guid.NewGuid().ToString() },
                new { Id = Guid.NewGuid().ToString(), MachineId = Guid.NewGuid().ToString() }
            };
        }
        catch
        {
            // Fallback logic
        }
    }

    private void SimulateRfidTap()
    {
        // Add fake optimistic result for lightning speed (< 3s rule)
        var fakeSession = new { Id = Guid.NewGuid().ToString(), MachineId = "SIM-MACH-01" };
        activeSessions.Insert(0, fakeSession);
        
        // Next, call API in background:
        // await httpClient.PostAsJsonAsync("/api/sessions/start", new { TagUid = "MOCK_TAG", MachineId = Guid.NewGuid() });
    }
}
