@page "/login"
@using WorldplayAMS.UI.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Worldplay AMS - Access</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>Worldplay AMS</h1>
        <p>Select your authorized role to access the system mock-up:</p>
        
        <div class="role-buttons">
            <button class="btn btn-admin" @onclick='() => DemoLogin("Admin")'>Admin Login</button>
            <button class="btn btn-tech" @onclick='() => DemoLogin("Technician")'>Technician Login</button>
            <button class="btn btn-staff" @onclick='() => DemoLogin("Staff")'>Staff Login</button>
        </div>
        
        <p class="note">This is a mock authentication interface. Strict Supabase JWT integration mapping will replace this.</p>
    </div>
</div>

<style>
    body { background-color: #2c3e50; margin: 0; }
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        width: 100vw;
    }
    .login-card {
        background: #ecf0f1;
        padding: 4rem;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        text-align: center;
        max-width: 500px;
        width: 90%;
    }
    .login-card h1 { color: #2c3e50; font-size: 2.2rem; }
    .role-buttons {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin: 2rem 0;
    }
    .btn {
        padding: 1.2rem;
        font-size: 1.2rem;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        color: white;
    }
    .btn-admin { background: #e74c3c; }
    .btn-tech { background: #f39c12; }
    .btn-staff { background: #3498db; }
    .note { color: #7f8c8d; font-size: 0.9rem; }
</style>

@code {
    private void DemoLogin(string role)
    {
        if (AuthStateProvider is SimulatedAuthStateProvider simulatedProvider)
        {
            simulatedProvider.LoginAs(role);
            Nav.NavigateTo("/");
        }
    }
}
