@page "/login"
@using WorldplayAMS.UI.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Worldplay AMS — Authentication</PageTitle>

<div class="login-bg">
    <div class="login-wrapper">

        <!-- Left decorative panel (desktop only) -->
        <div class="login-brand-panel" aria-hidden="true">
            <div class="brand-bg-glow"></div>
            <div class="brand-panel-content">
                <div class="brand-panel-logo">
                    <span class="bi bi-controller"></span>
                </div>
                <h2 class="brand-panel-title">Worldplay</h2>
                <p class="brand-panel-subtitle">Arcade Management System</p>
                <div class="brand-panel-badges">
                    <span class="badge-neon active"><span class="bi bi-record-circle-fill"></span> System Online</span>
                </div>
                <div class="brand-stats-grid mt-4">
                    <div class="brand-stat">
                        <span class="brand-stat-val">4</span>
                        <span class="brand-stat-lbl">Machines</span>
                    </div>
                    <div class="brand-stat">
                        <span class="brand-stat-val">0</span>
                        <span class="brand-stat-lbl">Active Sessions</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Auth Card -->
        <div class="login-card glass-card">
            <div class="login-card-header text-center mb-4">
                <div class="login-icon-ring mb-3">
                    <span class="bi bi-fingerprint" style="font-size: 2rem; color: var(--neon-cyan);"></span>
                </div>
                <h1 class="login-title">Staff Portal</h1>
                <p class="login-desc">Select your access level to continue</p>
            </div>

            <div class="login-roles">
                <button class="login-role-btn role-admin" @onclick='() => DemoLogin("Admin")'>
                    <div class="role-icon">
                        <span class="bi bi-shield-lock-fill"></span>
                    </div>
                    <div class="role-info">
                        <span class="role-name">Administrator</span>
                        <span class="role-desc">Full system access</span>
                    </div>
                    <span class="bi bi-chevron-right role-arrow"></span>
                </button>

                <button class="login-role-btn role-tech" @onclick='() => DemoLogin("Technician")'>
                    <div class="role-icon">
                        <span class="bi bi-wrench-adjustable-circle-fill"></span>
                    </div>
                    <div class="role-info">
                        <span class="role-name">Technician</span>
                        <span class="role-desc">Diagnostics & hardware</span>
                    </div>
                    <span class="bi bi-chevron-right role-arrow"></span>
                </button>

                <button class="login-role-btn role-staff" @onclick='() => DemoLogin("Staff")'>
                    <div class="role-icon">
                        <span class="bi bi-person-badge-fill"></span>
                    </div>
                    <div class="role-info">
                        <span class="role-name">Staff</span>
                        <span class="role-desc">Check-in & operations</span>
                    </div>
                    <span class="bi bi-chevron-right role-arrow"></span>
                </button>
            </div>

            <div class="login-footer">
                <span class="bi bi-lock-fill me-1" style="font-size:0.7rem;"></span>
                Secured via Supabase Auth · Demo Mode
            </div>
        </div>

    </div>
</div>

<style>
    .login-bg {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 4.25rem);
        padding: 2rem 1rem;
    }

    .login-wrapper {
        display: flex;
        gap: 0;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.06);
        max-width: 860px;
        width: 100%;
    }

    /* Brand left panel */
    .login-brand-panel {
        display: none;
        width: 300px;
        flex-shrink: 0;
        background: linear-gradient(165deg, rgba(157,0,255,0.22) 0%, rgba(0,240,255,0.08) 100%);
        border-right: 1px solid rgba(255,255,255,0.07);
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
    }
    @@media (min-width: 700px) { .login-brand-panel { display: flex; align-items: center; } }

    .brand-bg-glow {
        position: absolute;
        inset: -50%;
        background: radial-gradient(ellipse at 30% 40%, rgba(157,0,255,0.25), transparent 60%),
                    radial-gradient(ellipse at 70% 70%, rgba(0,240,255,0.15), transparent 60%);
        pointer-events: none;
    }

    .brand-panel-content { position: relative; z-index: 1; width: 100%; }

    .brand-panel-logo {
        width: 64px; height: 64px;
        background: linear-gradient(135deg, var(--neon-purple), var(--neon-cyan));
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; color: #fff;
        margin-bottom: 1.25rem;
        box-shadow: 0 0 24px rgba(157,0,255,0.5);
    }

    .brand-panel-title {
        font-size: 1.6rem; font-weight: 800;
        background: linear-gradient(135deg, #fff 30%, var(--neon-cyan));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.25rem;
    }

    .brand-panel-subtitle { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.25rem; }

    .brand-stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .brand-stat {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 0.85rem 1rem;
        text-align: center;
    }
    .brand-stat-val { display: block; font-family: var(--font-heading); font-size: 1.6rem; font-weight: 700; color: var(--text-primary); }
    .brand-stat-lbl { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); }

    /* Auth card */
    .login-card {
        flex: 1;
        border-radius: 0;
        border: none;
        padding: 2.75rem 2.5rem;
        background: var(--surface-base);
    }
    @@media (max-width: 699px) { .login-card { border-radius: 20px; } }

    .login-icon-ring {
        width: 70px; height: 70px;
        border-radius: 50%;
        background: rgba(0,240,255,0.07);
        border: 2px solid rgba(0,240,255,0.25);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto;
        animation: pulse-ring 3s ease-in-out infinite;
    }

    .login-title {
        font-size: 1.6rem; font-weight: 800;
        letter-spacing: 0.5px;
        color: var(--text-primary);
        margin-bottom: 0.3rem;
    }
    .login-desc { color: var(--text-secondary); font-size: 0.875rem; }

    /* Role buttons */
    .login-roles { display: flex; flex-direction: column; gap: 0.85rem; margin-bottom: 1.75rem; }

    .login-role-btn {
        display: flex;
        align-items: center;
        gap: 1rem;
        width: 100%;
        padding: 1rem 1.25rem;
        border-radius: 12px;
        border: 1px solid var(--surface-border-strong);
        background: var(--surface-raised);
        cursor: pointer;
        transition: all 0.25s ease;
        text-align: left;
    }
    .login-role-btn:hover {
        transform: translateX(4px);
    }

    .role-icon {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    .role-info { flex: 1; }
    .role-name { display: block; font-family: var(--font-heading); font-weight: 600; font-size: 0.9rem; color: var(--text-primary); }
    .role-desc { display: block; font-size: 0.75rem; color: var(--text-secondary); margin-top: 1px; }
    .role-arrow { color: var(--text-disabled); font-size: 0.8rem; transition: color 0.2s, transform 0.2s; }
    .login-role-btn:hover .role-arrow { color: var(--text-primary); transform: translateX(3px); }

    .role-admin { border-color: rgba(255,0,170,0.25); }
    .role-admin:hover { border-color: rgba(255,0,170,0.5); background: rgba(255,0,170,0.06); box-shadow: 0 0 20px rgba(255,0,170,0.1); }
    .role-admin .role-icon { background: rgba(255,0,170,0.12); color: var(--neon-magenta); }
    .role-admin .role-name { color: var(--neon-magenta); }

    .role-tech { border-color: rgba(0,240,255,0.25); }
    .role-tech:hover { border-color: rgba(0,240,255,0.5); background: rgba(0,240,255,0.05); box-shadow: 0 0 20px rgba(0,240,255,0.1); }
    .role-tech .role-icon { background: rgba(0,240,255,0.1); color: var(--neon-cyan); }
    .role-tech .role-name { color: var(--neon-cyan); }

    .role-staff { border-color: rgba(0,230,118,0.25); }
    .role-staff:hover { border-color: rgba(0,230,118,0.5); background: rgba(0,230,118,0.05); box-shadow: 0 0 20px rgba(0,230,118,0.1); }
    .role-staff .role-icon { background: rgba(0,230,118,0.12); color: var(--status-active); }
    .role-staff .role-name { color: var(--status-active); }

    .login-footer {
        text-align: center;
        font-size: 0.75rem;
        color: var(--text-disabled);
        padding-top: 1.25rem;
        border-top: 1px solid var(--surface-border);
    }
</style>

@code {
    private void DemoLogin(string role)
    {
        if (AuthStateProvider is SimulatedAuthStateProvider simulatedProvider)
        {
            simulatedProvider.LoginAs(role);
            Nav.NavigateTo("/");
        }
    }
}
