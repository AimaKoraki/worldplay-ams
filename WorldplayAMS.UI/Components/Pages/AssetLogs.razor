@page "/asset-logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Technician")]
@inject IHttpClientFactory ClientFactory

<PageTitle>Worldplay AMS — Asset Usage Logs</PageTitle>

<div class="logs-wrap">

    <!-- Page Header -->
    <div class="page-header mb-5">
        <div>
            <h1 class="page-title">
                <span class="bi bi-hdd-stack-fill me-3" style="color:var(--neon-cyan);"></span>Asset Usage Logs
            </h1>
            <p class="page-subtitle">Track machine uptime, usage history, and maintenance cycles</p>
        </div>
        <div class="header-actions">
            <button class="btn-neon btn-neon-cyan" @onclick="LoadLogs">
                <span class="bi bi-arrow-repeat"></span> Refresh
            </button>
        </div>
    </div>

    <!-- Summary Strip -->
    <div class="log-strip mb-5">
        <div class="strip-item">
            <span class="bi bi-journal-text" style="color:var(--neon-cyan);"></span>
            <span>@logs.Count Total Logs</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-check-circle-fill" style="color:var(--status-active);"></span>
            <span>@logs.Count(l => l.Status == "Completed") Completed</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-broadcast" style="color:var(--status-logging);"></span>
            <span>@logs.Count(l => l.Status == "Active") Active</span>
        </div>
        <div class="strip-divider"></div>
        <div class="strip-item">
            <span class="bi bi-clock" style="color:var(--neon-amber);"></span>
            <span>@totalUptime min Total Tracked</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="empty-state-full">
            <span class="bi bi-arrow-repeat rotating" style="font-size:2.5rem; color:var(--neon-cyan);"></span>
            <p class="mt-3">Loading usage logs...</p>
        </div>
    }
    else if (!logs.Any())
    {
        <div class="glass-card empty-state-full">
            <span class="bi bi-hdd-rack" style="font-size:3rem; color:var(--text-disabled);"></span>
            <h3 class="mt-3 text-white">No Usage Logs Recorded</h3>
            <p class="mt-1 text-muted-custom">Machine usage will be tracked once sessions are started from the Diagnostics panel.</p>
        </div>
    }
    else
    {
        <div class="log-grid">
            @foreach (var log in logs)
            {
                var isActive = log.Status == "Active";
                <div class="glass-card log-card @(isActive ? "log-active" : "log-completed")">
                    <div class="log-accent-bar"></div>

                    <div class="log-header">
                        <div class="log-icon-wrap @(isActive ? "icon-active" : "icon-completed")">
                            <span class="bi @(isActive ? "bi-broadcast" : "bi-check-circle-fill")"></span>
                        </div>
                        <div class="log-title-block">
                            <h3 class="log-name">NODE-@log.MachineId.ToString().Substring(0, 6).ToUpper()</h3>
                            <span class="badge-neon @(isActive ? "logging" : "active")">
                                <span class="bi @(isActive ? "bi-record-circle-fill" : "bi-check-lg")"></span>
                                @log.Status
                            </span>
                        </div>
                    </div>

                    <div class="log-meta">
                        <div class="meta-item">
                            <span class="meta-label">Log ID</span>
                            <span class="meta-value font-mono">@log.Id.ToString().Substring(0, 8).ToUpper()</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Started</span>
                            <span class="meta-value">@log.StartTime.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Ended</span>
                            <span class="meta-value">@(log.EndTime.HasValue ? log.EndTime.Value.ToLocalTime().ToString("MMM dd, HH:mm") : "In Progress")</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Duration</span>
                            <span class="meta-value" style="color:var(--neon-amber);">
                                @if (log.DurationMinutes.HasValue)
                                {
                                    @($"{log.DurationMinutes} min")
                                }
                                else if (isActive)
                                {
                                    <span style="color:var(--status-logging);">Recording...</span>
                                }
                                else
                                {
                                    @("—")
                                }
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .logs-wrap { padding-bottom: 2rem; }

    .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 40%, var(--neon-cyan) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
        display: flex;
        align-items: center;
    }
    .page-subtitle { color: var(--text-secondary); font-size: 0.875rem; margin-top: 0.3rem; }

    .log-strip {
        display: flex;
        align-items: center;
        background: var(--surface-base);
        border: 1px solid var(--surface-border);
        border-radius: var(--radius-md);
        padding: 0.9rem 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .strip-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-heading);
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-secondary);
    }
    .strip-divider { width: 1px; height: 20px; background: var(--surface-border); flex-shrink: 0; }

    /* Log grid */
    .log-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    /* Log cards */
    .log-card {
        padding: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    }
    .log-card:hover { transform: translateY(-4px); }

    .log-accent-bar { height: 3px; width: 100%; }
    .log-active .log-accent-bar  { background: linear-gradient(90deg, var(--status-logging), transparent); }
    .log-completed .log-accent-bar { background: linear-gradient(90deg, var(--status-active), transparent); }

    .log-active  { box-shadow: var(--shadow-card), 0 0 20px rgba(41,121,255,0.1); }
    .log-completed { box-shadow: var(--shadow-card); }

    .log-header {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.5rem 1.5rem 1rem;
    }

    .log-icon-wrap {
        width: 44px; height: 44px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    .icon-active    { background: rgba(41,121,255,0.12); color: var(--status-logging); }
    .icon-completed { background: rgba(0,230,118,0.12);  color: var(--status-active); }

    .log-title-block { flex: 1; }
    .log-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.4rem;
        line-height: 1.3;
    }

    /* Meta info */
    .log-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        padding: 1rem 1.5rem 1.5rem;
    }
    .meta-item { display: flex; flex-direction: column; gap: 2px; }
    .meta-label {
        font-size: 0.65rem; font-weight: 700;
        letter-spacing: 1.2px; text-transform: uppercase;
        color: var(--text-disabled);
    }
    .meta-value {
        font-size: 0.82rem; font-weight: 600;
        color: var(--text-primary);
    }

    .empty-state-full {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-height: 280px; text-align: center; color: var(--text-secondary);
    }
</style>

@code {
    private List<UsageLogDto> logs = new();
    private bool isLoading = true;
    private int totalUptime = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        isLoading = true;
        var client = ClientFactory.CreateClient("ApiClient");
        try
        {
            var result = await client.GetFromJsonAsync<List<UsageLogDto>>("/api/machines/logs");
            logs = result ?? new();
            totalUptime = logs.Sum(l => l.DurationMinutes ?? 0);
        }
        catch
        {
            logs = new();
        }
        isLoading = false;
    }

    private class UsageLogDto
    {
        public Guid Id { get; set; }
        public Guid MachineId { get; set; }
        public DateTime StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public int? DurationMinutes { get; set; }
        public string Status { get; set; } = string.Empty;
    }
}
