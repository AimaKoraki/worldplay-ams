@page "/access-denied"

<PageTitle>Worldplay AMS - Access Denied</PageTitle>

<div class="denied-container">
    <div class="denied-card">
        <div class="denied-icon">🚫</div>
        <h1>Access Denied</h1>
        <p class="denied-message">You do not have permission to access this page. Your current role does not include the required privileges.</p>
        <a href="/" class="btn btn-back">Return to Dashboard</a>
    </div>
</div>

<style>
    .denied-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        width: 100vw;
        background-color: #1e1e2f;
    }

    .denied-card {
        background: #2a2a40;
        padding: 4rem;
        border-radius: 24px;
        text-align: center;
        color: #ffffff;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        max-width: 550px;
        width: 90%;
        animation: fadeIn 0.4s ease-out;
    }

    .denied-icon {
        font-size: 5rem;
        margin-bottom: 1.5rem;
    }

    .denied-card h1 {
        font-size: 2.5rem;
        color: #e74c3c;
        margin-bottom: 1rem;
    }

    .denied-message {
        font-size: 1.15rem;
        color: #a4b0be;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .btn-back {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        background: #3498db;
        color: white;
        border: none;
        border-radius: 12px;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
    }

    .btn-back:hover {
        background: #2980b9;
        transform: scale(1.02);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
