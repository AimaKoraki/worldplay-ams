@using WorldplayAMS.UI.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="brand-header">
    <a class="navbar-brand" href="">
        <div class="brand-logo">
            <span class="bi bi-controller"></span>
        </div>
        <div class="brand-name">
            <span class="brand-main">Worldplay</span>
            <span class="brand-sub">AMS &nbsp;v2.0</span>
        </div>
    </a>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav>
        <AuthorizeView>
            <Authorized Context="authContext">

                <span class="nav-section-label">Navigation</span>

                <div class="nav-item mb-1">
                    <NavLink class="glass-nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-grid-1x2-fill nav-icon"></span>
                        Dashboard
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin,Staff" Context="staffContext">
                    <div class="nav-item mb-1">
                        <NavLink class="glass-nav-link" href="scanner">
                            <span class="bi bi-radar nav-icon"></span>
                            Check-In Scanner
                        </NavLink>
                    </div>
                    <div class="nav-item mb-1">
                        <NavLink class="glass-nav-link" href="sessions">
                            <span class="bi bi-clock-history nav-icon"></span>
                            Session History
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="Admin,Technician" Context="techContext">
                    <div class="nav-item mb-1">
                        <NavLink class="glass-nav-link" href="technician">
                            <span class="bi bi-gpu-card nav-icon"></span>
                            Diagnostics
                        </NavLink>
                    </div>
                    <div class="nav-item mb-1">
                        <NavLink class="glass-nav-link" href="asset-logs">
                            <span class="bi bi-hdd-stack-fill nav-icon"></span>
                            Asset Logs
                        </NavLink>
                    </div>
                </AuthorizeView>

                <!-- Spacer pushes sign-out to the bottom -->
                <div class="nav-bottom-spacer"></div>

                <div class="nav-divider"></div>

                <div class="nav-item mb-1">
                    <button class="glass-nav-link btn-logout" @onclick="Logout">
                        <span class="bi bi-box-arrow-left nav-icon"></span>
                        Sign Out
                    </button>
                </div>

            </Authorized>
            <NotAuthorized Context="notAuthContext">
                <span class="nav-section-label">Access</span>
                <div class="nav-item mb-1">
                    <NavLink class="glass-nav-link" href="login">
                        <span class="bi bi-fingerprint nav-icon"></span>
                        Authenticate
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private void Logout()
    {
        if (AuthStateProvider is SimulatedAuthStateProvider simulatedProvider)
        {
            simulatedProvider.Logout();
            Nav.NavigateTo("/login");
        }
    }
}
